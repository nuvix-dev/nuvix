# ============================================================================
# NUVIX ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and update values for your environment.
# Fields marked [REQUIRED IN PROD] are strictly validated on startup.
# ============================================================================

# ----------------------------------------------------------------------------
# ENVIRONMENT & APPLICATION
# ----------------------------------------------------------------------------
NODE_ENV=development
NUVIX_NAME="Nuvix"
NUVIX_PROJECT_ID=default
NUVIX_HOST=localhost
NUVIX_CONSOLE_URL=http://localhost:3000
NUVIX_FORCE_HTTPS=disabled

# ----------------------------------------------------------------------------
# SECURITY & ENCRYPTION
# ----------------------------------------------------------------------------
# [REQUIRED IN PROD] Min 32 characters
NUVIX_JWT_SECRET="your_super_secret_jwt_signature_key_here"

# [REQUIRED IN PROD] Min 16 characters
NUVIX_ENCRYPTION_KEY="your_16_char_enc_key"

# ----------------------------------------------------------------------------
# SERVER & PORTS
# ----------------------------------------------------------------------------
# Ports for the main client API and the internal Console/Dashboard API
NUVIX_API_PORT=4000
NUVIX_CONSOLE_API_PORT=4100

# ----------------------------------------------------------------------------
# DEFAULT ADMIN USER [REQUIRED]
# ----------------------------------------------------------------------------
# This account is automatically generated upon the very first database 
# migration/setup so you can log into the Nuvix Console.
NUVIX_ADMIN_EMAIL="admin@nuvix.in"
NUVIX_ADMIN_PASSWORD="CHANGE_ME_STRONG"

# ----------------------------------------------------------------------------
# DATABASE (PostgreSQL 18)
# ----------------------------------------------------------------------------
# [REQUIRED IN PROD] 
NUVIX_DATABASE_PASSWORD="CHANGE_ME_STRONG"

# Optional overrides (defaults to NUVIX_DATABASE_PASSWORD if left blank)
NUVIX_DATABASE_POSTGRES_PASSWORD=""
NUVIX_DATABASE_AUTHENTICATOR_PASSWORD=""
NUVIX_DATABASE_ADMIN_PASSWORD=""

NUVIX_DATABASE_HOST=localhost
NUVIX_DATABASE_PORT=5432
NUVIX_DATABASE_USER=postgres
NUVIX_DATABASE_SSL=false
NUVIX_DATABASE_MAX_CONNECTIONS=20

# Timeouts (in milliseconds)
NUVIX_DATABASE_QUERY_TIMEOUT=30000
NUVIX_DATABASE_IDLE_TIMEOUT=30000
NUVIX_DATABASE_CONNECTION_TIMEOUT=10000
NUVIX_DATABASE_STATEMENT_TIMEOUT=30000

# ----------------------------------------------------------------------------
# REDIS
# ----------------------------------------------------------------------------
# [REQUIRED IN PROD]
NUVIX_REDIS_HOST=localhost
NUVIX_REDIS_PORT=6379
NUVIX_REDIS_USER="default"
NUVIX_REDIS_PASSWORD="CHANGE_ME_STRONG"
NUVIX_REDIS_DB=0
NUVIX_REDIS_SECURE=false

# ----------------------------------------------------------------------------
# CORS & COOKIES
# ----------------------------------------------------------------------------
NUVIX_CORS_ORIGIN=http://localhost:3000
NUVIX_CORS_HEADERS=""
NUVIX_COOKIE_DOMAIN="localhost"
NUVIX_COOKIE_SAMESITE=lax
NUVIX_COOKIE_NAME=session

# ----------------------------------------------------------------------------
# SMTP / EMAIL
# ----------------------------------------------------------------------------
# [REQUIRED IN PROD]
NUVIX_SMTP_HOST=""
NUVIX_SMTP_PORT=587
NUVIX_SMTP_SECURE=false
NUVIX_SMTP_USER=""
NUVIX_SMTP_PASSWORD=""

# [REQUIRED] Must be valid email formats
NUVIX_SMTP_EMAIL_FROM="noreply@nuvix.in"
NUVIX_SMTP_SENDER="Nuvix System"
NUVIX_SMTP_REPLY_TO="support@nuvix.in"

# DKIM signing (optional but recommended for deliverability)
NUVIX_SMTP_DKIM_DOMAIN=""
NUVIX_SMTP_DKIM_KEY=""
NUVIX_SMTP_DKIM_PRIVATE_KEY=""

# System email addresses
NUVIX_SYSTEM_EMAIL_ADDRESS=support@nuvix.in
NUVIX_EMAIL_TEAM=team@localhost.test
NUVIX_EMAIL_SECURITY=""

# ----------------------------------------------------------------------------
# SMS (Twilio)
# ----------------------------------------------------------------------------
NUVIX_SMS_ENABLED=false
NUVIX_SMS_TWILIO_ACCOUNT_SID=""
NUVIX_SMS_TWILIO_AUTH_TOKEN=""
NUVIX_SMS_TWILIO_FROM_PHONE=""

# ----------------------------------------------------------------------------
# STORAGE & ASSETS
# ----------------------------------------------------------------------------
NUVIX_ASSETS_ROOT=assets
NUVIX_ASSETS_PUBLIC=public

# Storage limits (in bytes)
NUVIX_STORAGE_MAX_SIZE=5000000000      # 5GB per file
NUVIX_STORAGE_LIMIT=10000000000        # 10GB total limit

# ----------------------------------------------------------------------------
# LIMITS, QUOTAS & BATCH PROCESSING
# ----------------------------------------------------------------------------
NUVIX_LIMIT_PAGING=12
NUVIX_LIMIT_USERS=10000
NUVIX_LIMIT_USER_PASSWORD_HISTORY=10
NUVIX_LIMIT_USER_SESSIONS_MAX=100
NUVIX_LIMIT_USER_SESSIONS_DEFAULT=10

NUVIX_BATCH_SIZE=2000
NUVIX_BATCH_INTERVAL_MS=5000
NUVIX_CACHE_UPDATE=86400

# ----------------------------------------------------------------------------
# DEBUGGING, METRICS & LOGGING
# ----------------------------------------------------------------------------
# Feature Flags
NUVIX_ENABLE_API_LOGS=true
NUVIX_ENABLE_STATS=true
NUVIX_ENABLE_THROTTLING=true

# Log levels (comma-separated: log, error, warn, debug, verbose)
NUVIX_LOG_LEVELS=log,error,warn

# Debug output options
NUVIX_DEBUG_COLORS=true
NUVIX_DEBUG_JSON=false
NUVIX_DEBUG_ERRORS=false
NUVIX_DEBUG_FALLBACK_COOKIES=false
